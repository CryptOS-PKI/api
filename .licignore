# Deny everything by default, then allow specific source files.
*

# Allow our hand-written source files.
!*.proto
!*.go

# Allow directory traversal.
!*/

# Re-deny generated stubs (regenerated from .proto on every build).
go/**/*.pb.go
go/**/*.connect.go

# TypeScript codegen (regenerated from .proto on every build).
gen/ts/**

# Proto headers are hand-maintained in the .proto sources (golic v0.2.0 does not
# round-trip the post-syntax block comment); exclude them from the golic check.
*.proto
